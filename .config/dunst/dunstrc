[global]
monitor = 0
follow = mouse
width = 320
height = (40, 200)
origin = top-right
offset = (20,50)
notification_limit = 3

corner_radius = 8
padding = 12
horizontal_padding = 12
gap_size = 6
frame_width = 1
frame_color = "#313244"
separator_height = 0
transparency = 5

font = Hack-ZeroSlash 10
markup = yes
format = "<b>%s</b>\n%b"

icon_position = left
icon_theme = Papirus
max_icon_size = 48

word_wrap = yes
ellipsize = middle
stack_duplicates = true
hide_duplicate_count = true

mouse_left_click = do_action
mouse_middle_click = close_current
mouse_right_click = close_all

[urgency_low]
background = "#181825"    ; Mocha base
foreground = "#C6D0F5"    ; Text
timeout = 3

[urgency_normal]
background = "#181825"    ; Mocha mantle
foreground = "#F5E0DC"    ; Light text
timeout = 5

[urgency_critical]
background = "#181825"    ; Same as normal for consistency
foreground = "#F38BA8"    ; Pink/red for critical
timeout = 0
